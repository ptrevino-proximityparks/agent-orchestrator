# Terminal server ports (14800 range chosen to avoid conflicts with dev tools)
TERMINAL_PORT=14800                 # ttyd (iframe) terminal server
DIRECT_TERMINAL_PORT=14801          # Direct WebSocket terminal server with XDA support

# Public environment variables (exposed to browser)
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801

# Linear integration
# Webhook secret for validating Linear webhook signatures (HMAC-SHA256)
# Get this from your Linear webhook settings at https://linear.app/settings/api/webhooks
LINEAR_WEBHOOK_SECRET=your-webhook-secret-here

# Linear API key for making API calls to Linear (creating comments, updating issues, etc.)
# Generate a personal API key at https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
